<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for API 31+ (Android 12+).
    See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up the tracing progress so users keep their scores in Google Drive -->
        <include domain="sharedpref" path="tracing_progress.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Include progress during device-to-device transfers -->
        <include domain="sharedpref" path="tracing_progress.xml"/>
    </device-transfer>
</data-extraction-rules>